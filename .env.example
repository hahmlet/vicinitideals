# =============================================================================
# vicinitideals — environment variables
# Copy to .env and fill in values. Never commit .env to git.
# =============================================================================

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_PASSWORD=changeme-generate-strong-password

# =============================================================================
# FastAPI / SQLAlchemy
# =============================================================================
DATABASE_URL=postgresql+asyncpg://re_modeling:changeme-generate-strong-password@postgres:5432/re_modeling

# API authentication token (generate with: openssl rand -hex 32)
VICINITIDEALS_API_KEY=changeme-generate-with-openssl-rand-hex-32
# Session signing key (generate with: openssl rand -hex 32)
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# Error monitoring (BugSink — Sentry-SDK compatible)
# Leave empty to disable. Set to your BugSink DSN after T10 (provision BugSink LXC).
SENTRY_DSN=
ENVIRONMENT=production

# =============================================================================
# Transactional email (Resend — https://resend.com)
# =============================================================================
# API key from the Resend dashboard.  Leave empty to disable email sending
# (register / reset flows still work, they just log instead of sending).
RESEND_API_KEY=
# Sender address — must be on a domain verified with Resend
EMAIL_FROM=auth@viciniti.deals
EMAIL_FROM_NAME=Viciniti Deals
# Base URL used to build verification / reset links in email bodies
APP_BASE_URL=https://viciniti.deals
# Token lifetimes (seconds)
EMAIL_VERIFY_TOKEN_MAX_AGE_SECONDS=86400
PASSWORD_RESET_TOKEN_MAX_AGE_SECONDS=1800

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# Celery
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# =============================================================================
# Scraper (Stage 1C — LXC 134 Scrapling service)
# =============================================================================
LXC134_SCRAPLING_URL=http://192.168.1.134:8191
SCRAPE_INTERVAL_HOURS=6

# ProxyOn residential proxies (proxyon.io)
# Obtain credentials via the ProxyOn panel after ordering a residential subscription.
# Leave unset in local dev — scraper will run without proxy (test env only).
PROXYON_RESIDENTIAL_HOST=residential.proxyon.io
PROXYON_RESIDENTIAL_PORT=1111
PROXYON_RESIDENTIAL_USERNAME=
PROXYON_RESIDENTIAL_PASSWORD=

# Crexi authenticated account (dummy account — used only for Portland pagination bypass)
# Without these, Portland is capped at 50 results (non-auth limit).
CREXI_USERNAME=
CREXI_PASSWORD=

# Realie.ai property data enrichment (https://realie.ai)
# Free tier: 25 calls/month. Hard lock in code prevents overage.
# Obtain from: https://realie.ai (account dashboard)
REALIE_API_KEY=

# Gresham parcel lookup (REAL-65)
GRESHAM_ARCGIS_MAPSERVER_URL=https://gis.greshamoregon.gov/ext/rest/services/Taxlots/MapServer
GRESHAM_ARCGIS_TAXLOT_LAYER_ID=0
GRESHAM_ARCGIS_ADDRESS_LAYER_ID=0
GRESHAM_ARCGIS_TIMEOUT_SECONDS=20

# Clackamas parcel lookup (REAL-68)
CLACKAMAS_MAPS_BASE_URL=https://maps.clackamas.us
CLACKAMAS_MAPS_TIMEOUT_SECONDS=20

# Oregon City parcel lookup (REAL-69)
OREGONCITY_ARCGIS_ADDRESS_URL=https://maps.orcity.org/arcgis/rest/services/AddressPts_PUBLIC/MapServer/0/query
OREGONCITY_ARCGIS_TAXLOT_URL=https://maps.orcity.org/arcgis/rest/services/Taxlots_PUBLIC/MapServer/0/query
OREGONCITY_ARCGIS_TIMEOUT_SECONDS=20

# Portland exact-address parcel lookup (REAL-67)
PORTLANDMAPS_BASE_URL=https://www.portlandmaps.com/arcgis/rest/services
PORTLANDMAPS_TIMEOUT_SECONDS=20

# =============================================================================
# LoopNet RapidAPI (https://rapidapi.com/asyncsolutions-asyncsolutions-default/api/loopnet-api)
# =============================================================================
# Free tier: 100 calls/month. Second tier: 5,000 calls/month.
# Budget enforced in app/scrapers/loopnet.py BudgetGuard against api_call_log.
RAPIDAPI_KEY=
LOOPNET_RAPIDAPI_HOST=loopnet-api.p.rapidapi.com
LOOPNET_POLYGON_PATH=app/data/market_polygons.json
LOOPNET_MONTHLY_BUDGET=100
LOOPNET_BUDGET_SAFETY_MARGIN=5

# Seed experiment — set ENABLED=true plus an END_DATE (ISO YYYY-MM-DD) to
# collect 30 days of update-frequency data, then disable after analysis.
LOOPNET_EXPERIMENT_ENABLED=false
LOOPNET_EXPERIMENT_END_DATE=

# Categories that trigger ExtendedDetails fetch in TARGET polygons.
# Comma-separated. Options: multifamily, land, mixed_use, retail, office,
# industrial, flex, other. Comp-only polygons always restrict ED to multifamily.
LOOPNET_TARGET_ED_CATEGORIES=multifamily,land,mixed_use

# Use bulkDetails (20 IDs/call) for cheap pre-classification before spending
# SaleDetails calls. Cuts call volume ~55-60% for high-volume sweeps.
LOOPNET_USE_BULK_TRIAGE=true
